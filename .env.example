# Copy to .env (gitignored) and fill in values to switch ingestion-go
# from local fixtures to a real FHIR Bulk Data $export against Epic
# (or any SMART Backend Services endpoint).
#
#   cp .env.example .env
#   # edit the values
#   docker compose up -d --force-recreate ingestion-go
#
# When .env is absent or SOURCE_MODE is unset / FIXTURES, ingestion-go
# reads the local NDJSON fixtures shipped in services/ingestion-go/fixtures.

# FIXTURES (default) or BULK_EXPORT
SOURCE_MODE=FIXTURES

# --- BULK_EXPORT settings (only used when SOURCE_MODE=BULK_EXPORT) -----------
# The FHIR R4 base of the EHR.
EPIC_FHIR_BASE=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# SMART Backend Services client id registered at fhir.epic.com.
EPIC_CLIENT_ID=

# RSA private key (PEM). Either inline the PEM block here — escape
# newlines as \n — or mount the file and use ENV var indirection.
EPIC_PRIVATE_KEY_PEM=

# kid published in your JWKS endpoint (must match the registered JWKS).
EPIC_KEY_ID=ingestion-go-1

# Space-separated SMART scopes. Defaults to system-level reads.
EPIC_SCOPES=system/Patient.read system/Condition.read system/Observation.read system/Encounter.read

# Comma-separated FHIR ResourceTypes for the _type $export filter.
EPIC_RESOURCE_TYPES=Patient,Condition,Observation,Encounter

# Polling cadence and ceiling for the $export status URL.
EPIC_POLL_INTERVAL=5s
EPIC_POLL_MAX_RETRIES=60
